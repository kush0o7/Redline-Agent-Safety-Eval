# ── Required ──────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg://redline:redline@postgres:5432/redline
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=change-me          # change before exposing publicly

# ── Provider: pick ONE block ──────────────────────────────────────────────────

# Option A — OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
DEFAULT_MODEL=gpt-4o-mini

# Option B — Any OpenAI-compatible endpoint (your own agent, Together, Groq, LiteLLM proxy, etc.)
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://your-agent.example.com/v1
# OPENAI_API_KEY=your-key-or-empty
# DEFAULT_MODEL=your-model-name

# Option C — Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_MODEL=claude-3-5-sonnet-20240620

# Option D — Ollama (local, free)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# DEFAULT_MODEL=llama3.1

# Option E — AWS Bedrock
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_PROFILE=default
# DEFAULT_MODEL=anthropic.claude-opus-4-6-v1

# Option F — Fake (no API calls, for testing Redline itself)
# LLM_PROVIDER=fake
# DEV_FAKE_PROVIDER=true
# DEFAULT_MODEL=fake

# ── Judge (LLM-as-judge scoring) ─────────────────────────────────────────────
# Uses LiteLLM — supports any provider with the right prefix.
#
# FREE option (Groq — 14,400 requests/day free, sign up at console.groq.com):
#   GROQ_API_KEY=gsk_...
#   JUDGE_MODEL=groq/llama-3.1-8b-instant      # fast, free
#   JUDGE_MODEL=groq/llama-3.3-70b-versatile   # higher quality, still free
#
# OpenAI option:
#   JUDGE_MODEL=gpt-4o-mini                    # cheap, good quality
#   JUDGE_MODEL=gpt-4o                         # highest quality
#
# Anthropic option:
#   JUDGE_MODEL=claude-haiku-4-5-20251001      # cheap
#   JUDGE_MODEL=claude-sonnet-4-6              # highest quality
#
# Local/free via Ollama:
#   JUDGE_MODEL=ollama/llama3.1                # completely free, runs locally
#
JUDGE_MODEL=gpt-4o-mini
JUDGE_TEMPERATURE=0.0
DEV_FAKE_JUDGE=false             # true = keyword heuristics, no LLM calls (CI mode)
# GROQ_API_KEY=                  # only needed when JUDGE_MODEL starts with groq/

# ── Optional tuning ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20
LOG_LEVEL=INFO
